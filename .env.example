# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────

# PostgreSQL connection string (e.g. postgres://user:pass@localhost:5432/dbname)
DATABASE_URL=

# Secret used for session signing & encrypting stored LLM API keys.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ──────────────────────────────────────────────
# Optional – Admin
# ──────────────────────────────────────────────

# Comma-separated list of emails that get admin access (promo codes, etc.)
ADMIN_EMAILS=

# ──────────────────────────────────────────────
# Optional – Platform LLM (fallback for users without their own key)
# ──────────────────────────────────────────────

# AWS credentials for Bedrock (used by callLlmWithPlatformCredentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS region for Bedrock (default: us-east-1)
PLATFORM_LLM_REGION=

# Bedrock model ID (default: minimax.minimax-m2.5)
PLATFORM_LLM_MODEL=

# ──────────────────────────────────────────────
# Optional – Auth URL override
# ──────────────────────────────────────────────

# Override the base URL Better Auth uses for callbacks / cookie domain.
# Normally auto-detected from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
# Only set this if you need a custom domain or local override.
BETTER_AUTH_URL=

# ──────────────────────────────────────────────
# Optional – PostHog Analytics
# ──────────────────────────────────────────────

# PostHog project API key (from PostHog > Project > Settings)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog host (default: https://us.i.posthog.com for US cloud)
NEXT_PUBLIC_POSTHOG_HOST=
